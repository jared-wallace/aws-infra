# Copy to secrets.tfvars and fill in real values.
# Never commit secrets.tfvars — it is gitignored.
#
# Usage: terraform apply -var-file="secrets.tfvars"

db_password         = "CHANGEME"
admin_email         = "admin@example.com"
admin_password_hash = "$2a$12$CHANGEME_run_make_hash-password"
session_secret      = "generate-a-random-32-char-string-here"
api_token           = "generate-a-random-token-for-api-push"
